# Copy this file to .env and fill in real values from your Supabase project settings.
# Supabase Dashboard > Project Settings > API and > Database.

# --- Prisma (Database > Connection string) ---
# Pooled connection (via Supavisor/pgbouncer) - used at runtime
DATABASE_URL="postgresql://postgres.xxxxxxxx:YOUR_DB_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection - used by `prisma migrate` only
DIRECT_URL="postgresql://postgres.xxxxxxxx:YOUR_DB_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# --- Supabase client (Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# Server-only - never expose to the browser, never commit
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
